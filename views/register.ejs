<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register - Haki Kenya</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="bg-gray-50 min-h-screen flex">
  <div class="max-w-md mx-auto mt-16 w-full px-4">
    <a href="/" class="text-green-700 font-bold text-xl mb-6 block text-center"><i class="fas fa-balance-scale mr-2"></i>Haki Kenya</a>
    <div class="bg-white p-8 rounded-xl shadow-md">
      <h2 class="text-2xl font-bold mb-6 text-center">Create Your Account</h2>
      <% if (error) { %><div class="bg-red-100 text-red-700 p-3 rounded mb-4"><%= error %></div><% } %>
      <form method="POST">
        <div class="mb-4">
          <label class="block text-gray-700 mb-1">Full Name</label>
          <input type="text" name="name" required class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-green-500">
        </div>
        <div class="mb-4">
          <label class="block text-gray-700 mb-1">Email</label>
          <input type="email" name="email" required class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-green-500">
        </div>
        <div class="mb-4">
          <label class="block text-gray-700 mb-1">Password</label>
          <input type="password" name="password" required class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-green-500">
        </div>
        <div class="mb-4">
          <label class="block text-gray-700 mb-1">National ID (Optional)</label>
          <input type="text" name="national_id" class="w-full px-4 py-2 border rounded-lg">
        </div>
        <div class="mb-4">
          <label class="block text-gray-700 mb-1">Phone</label>
          <input type="text" name="phone" class="w-full px-4 py-2 border rounded-lg">
        </div>
        <div class="mb-6">
          <label class="block text-gray-700 mb-1">I am a...</label>
          <select name="role" class="w-full px-4 py-2 border rounded-lg">
            <option value="applicant">Job Applicant</option>
            <option value="recruiter">Recruiter (Government Agency)</option>
          </select>
        </div>
        <button type="submit" class="w-full bg-green-700 text-white py-3 rounded-lg font-bold hover:bg-green-800">
          <i class="fas fa-user-plus mr-2"></i>Register
        </button>
      </form>
      <p class="text-center mt-4 text-gray-600">Already have an account? <a href="/login" class="text-green-700 font-semibold">Login</a></p>
    </div>
  </div>
</body>
</html>
