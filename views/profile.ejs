<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Profile - Haki Kenya</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="bg-gray-50">
  <nav class="bg-green-700 text-white shadow-lg">
    <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
      <a href="/" class="text-2xl font-bold"><i class="fas fa-balance-scale mr-2"></i>Haki Kenya</a>
      <div class="space-x-4">
        <a href="/dashboard" class="hover:text-green-200"><i class="fas fa-home"></i></a>
        <a href="/profile" class="hover:text-green-200"><i class="fas fa-user"></i></a>
        <a href="/jobs" class="hover:text-green-200"><i class="fas fa-briefcase"></i></a>
        <a href="/logout" class="hover:text-green-200"><i class="fas fa-sign-out-alt"></i></a>
      </div>
    </div>
  </nav>

  <div class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold mb-6">My Profile</h1>

    <div class="bg-white p-6 rounded-xl shadow mb-6">
      <h2 class="text-lg font-bold mb-4"><i class="fas fa-id-card text-green-600 mr-2"></i>Personal Info</h2>
      <p><strong>Unique Code:</strong> <span class="bg-green-100 px-3 py-1 rounded font-mono"><%= user.unique_code %></span></p>
      <p class="text-sm text-gray-500 mt-1">This code is what recruiters see. Your identity stays hidden.</p>
    </div>

    <div class="bg-white p-6 rounded-xl shadow mb-6">
      <h2 class="text-lg font-bold mb-4"><i class="fas fa-upload text-green-600 mr-2"></i>Upload CV / Documents</h2>
      <form action="/profile/upload-cv" method="POST" enctype="multipart/form-data" class="border-2 border-dashed border-gray-300 p-6 rounded-lg text-center">
        <i class="fas fa-file-pdf text-4xl text-gray-400 mb-3"></i>
        <p class="mb-2">Upload your CV (PDF, DOCX, or TXT)</p>
        <input type="file" name="cv" accept=".pdf,.docx,.txt" required class="mb-3">
        <button type="submit" class="bg-green-700 text-white px-6 py-2 rounded-lg hover:bg-green-800"><i class="fas fa-upload mr-2"></i>Upload</button>
      </form>

      <% if (docs && docs.length > 0) { %>
        <h3 class="font-bold mt-4 mb-2">Uploaded Documents</h3>
        <ul class="space-y-2">
          <% docs.forEach(doc => { %>
          <li class="bg-gray-50 p-3 rounded flex items-center">
            <i class="fas fa-file-alt text-green-600 mr-3"></i>
            <span><%= doc.filename %></span>
            <span class="ml-auto text-xs text-gray-400"><%= new Date(doc.uploaded_at).toLocaleDateString() %></span>
          </li>
          <% }); %>
        </ul>
      <% } %>
    </div>

    <div class="bg-white p-6 rounded-xl shadow">
      <h2 class="text-lg font-bold mb-4"><i class="fas fa-pen text-green-600 mr-2"></i>Profile Details</h2>
      <form method="POST">
        <div class="mb-4">
          <label class="block text-gray-700 mb-1">Bio / Summary</label>
          <textarea name="bio" rows="3" class="w-full px-4 py-2 border rounded-lg"><%= applicant?.bio || '' %></textarea>
        </div>
        <div class="mb-4">
          <label class="block text-gray-700 mb-1">Skills (comma separated)</label>
          <input type="text" name="skills" value="<%= applicant?.skills || '' %>" class="w-full px-4 py-2 border rounded-lg" placeholder="e.g. Chemistry, Data Analysis, Research">
        </div>
        <div class="mb-4">
          <label class="block text-gray-700 mb-1">Education</label>
          <textarea name="education" rows="3" class="w-full px-4 py-2 border rounded-lg" placeholder="e.g. BSc Industrial Chemistry, Maseno University, 2021"><%= applicant?.education || '' %></textarea>
        </div>
        <div class="mb-4">
          <label class="block text-gray-700 mb-1">Experience</label>
          <textarea name="experience" rows="3" class="w-full px-4 py-2 border rounded-lg" placeholder="e.g. 3 years at Kenya Bureau of Standards"><%= applicant?.experience || '' %></textarea>
        </div>
        <button type="submit" class="bg-green-700 text-white px-6 py-2 rounded-lg hover:bg-green-800"><i class="fas fa-save mr-2"></i>Save Profile</button>
      </form>
    </div>
  </div>
</body>
</html>
