<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Post Job - Haki Kenya</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="bg-gray-50">
  <nav class="bg-green-700 text-white shadow-lg">
    <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
      <a href="/" class="text-2xl font-bold"><i class="fas fa-balance-scale mr-2"></i>Haki Kenya</a>
      <span class="text-sm bg-yellow-500 text-green-900 px-2 py-1 rounded font-bold">RECRUITER</span>
      <div class="space-x-4">
        <a href="/recruiter/dashboard" class="hover:text-green-200">Dashboard</a>
        <a href="/logout" class="hover:text-green-200">Logout</a>
      </div>
    </div>
  </nav>

  <div class="max-w-3xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold mb-6">Post a New Job</h1>
    <div class="bg-white p-6 rounded-xl shadow">
      <% if (error) { %><div class="bg-red-100 text-red-700 p-3 rounded mb-4"><%= error %></div><% } %>
      <form method="POST">
        <div class="mb-4">
          <label class="block text-gray-700 mb-1 font-semibold">Job Title</label>
          <input type="text" name="title" required class="w-full px-4 py-2 border rounded-lg" placeholder="e.g. Industrial Chemist">
        </div>
        <div class="mb-4">
          <label class="block text-gray-700 mb-1 font-semibold">Department / Ministry</label>
          <input type="text" name="department" required class="w-full px-4 py-2 border rounded-lg" placeholder="e.g. Ministry of Health">
        </div>
        <div class="mb-4">
          <label class="block text-gray-700 mb-1 font-semibold">Location</label>
          <input type="text" name="location" class="w-full px-4 py-2 border rounded-lg" placeholder="e.g. Nairobi, Kenya">
        </div>
        <div class="mb-4">
          <label class="block text-gray-700 mb-1 font-semibold">Job Description</label>
          <textarea name="description" rows="6" required class="w-full px-4 py-2 border rounded-lg" placeholder="Describe the role, responsibilities, and context..."></textarea>
        </div>
        <div class="mb-4">
          <label class="block text-gray-700 mb-1 font-semibold">Requirements (for AI matching)</label>
          <textarea name="requirements" rows="6" required class="w-full px-4 py-2 border rounded-lg" placeholder="List required skills, qualifications, experience. The AI will match these against CVs.&#10;&#10;Example:&#10;- BSc in Industrial Chemistry&#10;- 3+ years lab experience&#10;- Knowledge of ISO standards&#10;- Data analysis skills"></textarea>
          <p class="text-sm text-gray-500 mt-1"><i class="fas fa-robot mr-1"></i>The AI engine scans this section to match candidates.</p>
        </div>
        <button type="submit" class="w-full bg-green-700 text-white py-3 rounded-lg font-bold hover:bg-green-800">
          <i class="fas fa-plus-circle mr-2"></i>Post Job & Enable AI Screening
        </button>
      </form>
    </div>
  </div>
</body>
</html>
