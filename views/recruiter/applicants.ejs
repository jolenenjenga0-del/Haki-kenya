<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Applicants - Haki Kenya</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    .ai-card { transition: all 0.2s; }
    .ai-card:hover { transform: translateY(-2px); box-shadow: 0 8px 16px rgba(0,0,0,0.1); }
  </style>
</head>
<body class="bg-gray-50">
  <nav class="bg-green-700 text-white shadow-lg">
    <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
      <a href="/" class="text-2xl font-bold"><i class="fas fa-balance-scale mr-2"></i>Haki Kenya</a>
      <span class="text-sm bg-yellow-500 text-green-900 px-2 py-1 rounded font-bold">RECRUITER</span>
      <div class="space-x-4">
        <a href="/recruiter/dashboard" class="hover:text-green-200">Dashboard</a>
        <a href="/logout" class="hover:text-green-200">Logout</a>
      </div>
    </div>
  </nav>

  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="flex justify-between items-center mb-6">
      <div>
        <h1 class="text-2xl font-bold"><%= job.title %></h1>
        <p class="text-gray-500"><%= job.department %> | <span class="text-green-600 font-semibold"><%= shortlisted %> shortlisted</span></p>
      </div>
      <a href="/recruiter/dashboard" class="text-gray-500 hover:text-gray-700">&larr; Back to Dashboard</a>
    </div>

    <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-6">
      <p class="text-sm text-yellow-800">
        <i class="fas fa-robot mr-2"></i>
        <strong>AI Screening Active.</strong> Candidates are identified by their unique code only.
        The AI evaluation below tells you <strong>why each candidate is suited</strong> based on their CV vs. job requirements.
        No names, no bias.
      </p>
    </div>

    <% if (applications.length === 0) { %>
      <div class="bg-white p-12 rounded-xl shadow text-center text-gray-500">
        <i class="fas fa-inbox text-5xl mb-4 text-gray-300"></i>
        <p class="text-lg">No applications received yet.</p>
      </div>
    <% } else { %>
      <div class="space-y-4">
        <% applications.forEach((app, idx) => { %>
        <div class="bg-white rounded-xl shadow ai-card overflow-hidden">
          <div class="p-6">
            <div class="flex justify-between items-start">
              <div>
                <div class="flex items-center gap-3">
                  <span class="text-2xl font-bold text-gray-300">#<%= idx + 1 %></span>
                  <h3 class="text-xl font-bold font-mono text-green-800"><%= app.applicant_code %></h3>
                  <% if (app.shortlisted) { %>
                    <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-bold">SHORTLISTED</span>
                  <% } else if (app.status === 'rejected') { %>
                    <span class="bg-red-100 text-red-700 px-3 py-1 rounded-full text-xs">REJECTED</span>
                  <% } %>
                </div>
                <p class="text-gray-400 text-xs mt-1">Unique Code — candidate identity is anonymous</p>
              </div>
              <div class="text-right flex items-center gap-3">
                <div>
                  <div class="text-3xl font-bold <%= app.ai_score >= 70 ? 'text-green-600' : app.ai_score >= 45 ? 'text-yellow-600' : 'text-gray-500' %>"><%= Math.round(app.ai_score) %>%</div>
                  <div class="text-xs text-gray-500">AI Match Score</div>
                </div>
              </div>
            </div>

            <!-- AI Analysis Section -->
            <div class="mt-4 p-4 bg-blue-50 rounded-lg border border-blue-200">
              <div class="flex items-start gap-3">
                <i class="fas fa-robot text-blue-600 text-xl mt-1"></i>
                <div>
                  <h4 class="font-bold text-blue-800 text-sm">AI EVALUATION: Why this candidate is suited</h4>
                  <p class="text-blue-900 mt-1"><%= app.ai_summary %></p>

                  <% if (app.criteria_matched) { %>
                  <div class="mt-2">
                    <p class="text-xs font-semibold text-blue-700 mb-1">Matching Criteria:</p>
                    <div class="flex flex-wrap gap-1">
                      <% JSON.parse(app.criteria_matched).forEach(c => { %>
                      <span class="bg-green-100 text-green-700 text-xs px-2 py-1 rounded"><%= c %></span>
                      <% }); %>
                    </div>
                  </div>
                  <% } %>

                  <details class="mt-2">
                    <summary class="text-xs text-blue-600 cursor-pointer hover:text-blue-800">View CV excerpt</summary>
                    <pre class="mt-2 text-xs text-gray-600 bg-white p-2 rounded max-h-32 overflow-y-auto"><%= app.cv_text?.substring(0, 1500) || 'No CV text available' %></pre>
                  </details>
                </div>
              </div>
            </div>

            <% if (!app.shortlisted && app.status !== 'rejected') { %>
            <div class="mt-4 flex gap-3">
              <form method="POST" action="/recruiter/applications/<%= app.id %>/shortlist" class="flex-1 flex gap-2">
                <input type="text" name="criteria" placeholder="Criteria (e.g. Top 10% Industrial Chemistry)" class="flex-1 px-3 py-2 border rounded text-sm" required value="AI Score: <%= Math.round(app.ai_score) %>%">
                <input type="text" name="reason" placeholder="Reason (optional)" class="flex-1 px-3 py-2 border rounded text-sm" value="<%= app.ai_summary.substring(0, 100) %>">
                <button type="submit" class="bg-green-700 text-white px-4 py-2 rounded-lg hover:bg-green-800 text-sm font-semibold">
                  <i class="fas fa-check mr-1"></i> Shortlist
                </button>
              </form>
              <form method="POST" action="/recruiter/applications/<%= app.id %>/reject">
                <button type="submit" class="bg-red-100 text-red-700 px-4 py-2 rounded-lg hover:bg-red-200 text-sm" onclick="return confirm('Reject this applicant?')">
                  <i class="fas fa-times mr-1"></i> Reject
                </button>
              </form>
            </div>
            <% } %>
          </div>
        </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</body>
</html>
