<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Browse Jobs - Haki Kenya</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="bg-gray-50">
  <nav class="bg-green-700 text-white shadow-lg">
    <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
      <a href="/" class="text-2xl font-bold"><i class="fas fa-balance-scale mr-2"></i>Haki Kenya</a>
      <div class="space-x-4">
        <a href="/dashboard" class="hover:text-green-200"><i class="fas fa-home"></i></a>
        <a href="/profile" class="hover:text-green-200"><i class="fas fa-user"></i></a>
        <a href="/jobs" class="hover:text-green-200"><i class="fas fa-briefcase"></i></a>
        <a href="/logout" class="hover:text-green-200"><i class="fas fa-sign-out-alt"></i></a>
      </div>
    </div>
  </nav>

  <div class="max-w-5xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold mb-6"><i class="fas fa-search mr-2 text-green-700"></i>Open Government Positions</h1>

    <% if (applied) { %>
    <div class="bg-blue-100 text-blue-700 p-4 rounded-lg mb-6"><i class="fas fa-check-circle mr-2"></i>Application submitted! AI is now evaluating your profile.</div>
    <% } %>

    <% if (jobs.length === 0) { %>
      <div class="bg-white p-12 rounded-xl shadow text-center text-gray-500">
        <i class="fas fa-inbox text-5xl mb-4 text-gray-300"></i>
        <p class="text-lg">No open positions at the moment.</p>
        <p class="text-sm">Check back later for new listings.</p>
      </div>
    <% } else { %>
      <div class="space-y-4">
        <% jobs.forEach(job => { %>
        <div class="bg-white p-6 rounded-xl shadow hover:shadow-lg transition">
          <div class="flex justify-between items-start">
            <div>
              <h2 class="text-xl font-bold text-green-800"><%= job.title %></h2>
              <p class="text-gray-500"><i class="fas fa-building mr-1"></i><%= job.department %> <% if(job.location) { %>| <i class="fas fa-map-marker-alt mr-1"></i><%= job.location %><% } %></p>
            </div>
            <% if (appliedJobIds.has(job.id)) { %>
              <span class="bg-gray-100 text-gray-500 px-4 py-2 rounded-lg text-sm font-semibold">Applied</span>
            <% } else { %>
              <a href="/jobs/<%= job.id %>/apply" class="bg-green-700 text-white px-6 py-2 rounded-lg hover:bg-green-800 font-semibold">Apply Now</a>
            <% } %>
          </div>
          <p class="text-gray-600 mt-3"><%= job.description.substring(0, 200) %><%= job.description.length > 200 ? '...' : '' %></p>
          <div class="mt-3 text-sm text-gray-500">
            <strong>Requirements:</strong> <%= job.requirements.substring(0, 150) %><%= job.requirements.length > 150 ? '...' : '' %>
          </div>
        </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</body>
</html>
