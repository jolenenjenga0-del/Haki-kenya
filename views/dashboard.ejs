<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - Haki Kenya</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="bg-gray-50">
  <nav class="bg-green-700 text-white shadow-lg">
    <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
      <a href="/" class="text-2xl font-bold"><i class="fas fa-balance-scale mr-2"></i>Haki Kenya</a>
      <div class="space-x-4">
        <span class="text-green-200"><%= user.name %></span>
        <a href="/dashboard" class="hover:text-green-200"><i class="fas fa-home"></i></a>
        <a href="/profile" class="hover:text-green-200"><i class="fas fa-user"></i></a>
        <a href="/jobs" class="hover:text-green-200"><i class="fas fa-briefcase"></i></a>
        <a href="/logout" class="hover:text-green-200"><i class="fas fa-sign-out-alt"></i></a>
      </div>
    </div>
  </nav>

  <div class="max-w-5xl mx-auto px-4 py-8">
    <div class="bg-green-100 border-l-4 border-green-700 p-6 rounded-lg mb-8">
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-2xl font-bold text-green-900">Karibu, <%= user.name %>!</h1>
          <p class="text-green-700 mt-1">Your anonymous recruitment code: <strong class="text-lg bg-white px-3 py-1 rounded"><%= user.unique_code %></strong></p>
          <p class="text-sm text-green-600 mt-1"><i class="fas fa-info-circle mr-1"></i>Share this code with recruiters after shortlisting. They will NOT see your name.</p>
        </div>
        <div class="text-right">
          <div class="text-3xl font-bold text-green-700"><%= openJobs %></div>
          <div class="text-green-600">Open Jobs</div>
        </div>
      </div>
    </div>

    <% if (applied) { %>
    <div class="bg-blue-100 text-blue-700 p-4 rounded-lg mb-6"><i class="fas fa-check-circle mr-2"></i>Application submitted successfully! The AI is reviewing your profile.</div>
    <% } %>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <a href="/profile" class="bg-white p-6 rounded-xl shadow hover:shadow-lg transition">
        <i class="fas fa-user-graduate text-green-600 text-3xl mb-3"></i>
        <h3 class="font-bold">My Profile</h3>
        <p class="text-sm text-gray-500">Upload CV, add skills and education</p>
      </a>
      <a href="/jobs" class="bg-white p-6 rounded-xl shadow hover:shadow-lg transition">
        <i class="fas fa-search text-green-600 text-3xl mb-3"></i>
        <h3 class="font-bold">Browse Jobs</h3>
        <p class="text-sm text-gray-500"><%= openJobs %> open positions available</p>
      </a>
      <a href="/public/shortlist" class="bg-white p-6 rounded-xl shadow hover:shadow-lg transition">
        <i class="fas fa-list text-green-600 text-3xl mb-3"></i>
        <h3 class="font-bold">Public Shortlists</h3>
        <p class="text-sm text-gray-500">View transparent shortlisting results</p>
      </a>
    </div>

    <h2 class="text-xl font-bold mb-4">My Applications</h2>
    <% if (applications.length === 0) { %>
      <div class="bg-white p-8 rounded-xl shadow text-center text-gray-500">
        <i class="fas fa-file-alt text-4xl mb-3 text-gray-300"></i>
        <p>You haven't applied to any jobs yet.</p>
        <a href="/jobs" class="text-green-700 font-semibold mt-2 inline-block">Browse open positions &rarr;</a>
      </div>
    <% } else { %>
      <div class="space-y-4">
        <% applications.forEach(app => { %>
        <div class="bg-white p-5 rounded-xl shadow flex justify-between items-center">
          <div>
            <h3 class="font-bold text-lg"><%= app.job_title %></h3>
            <p class="text-gray-500 text-sm"><%= app.department %></p>
            <p class="text-sm mt-1">
              <span class="text-gray-500">Status:</span>
              <% if (app.shortlisted) { %>
                <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs font-bold">SHORTLISTED</span>
              <% } else if (app.status === 'rejected') { %>
                <span class="bg-red-100 text-red-700 px-2 py-1 rounded text-xs">Not Selected</span>
              <% } else { %>
                <span class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded text-xs">Under Review</span>
              <% } %>
            </p>
          </div>
          <div class="text-right">
            <div class="text-2xl font-bold text-green-700"><%= Math.round(app.ai_score) %>%</div>
            <div class="text-xs text-gray-500">AI Score</div>
          </div>
        </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</body>
</html>
