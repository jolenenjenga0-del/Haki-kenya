<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Haki Kenya</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="bg-gray-50">
  <nav class="bg-green-700 text-white shadow-lg">
    <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
      <a href="/" class="text-2xl font-bold"><i class="fas fa-balance-scale mr-2"></i>Haki Kenya</a>
      <span class="text-sm bg-red-500 text-white px-2 py-1 rounded font-bold">ADMIN</span>
      <div class="space-x-4">
        <a href="/logout" class="hover:text-green-200">Logout</a>
      </div>
    </div>
  </nav>

  <div class="max-w-7xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold mb-6">Admin Dashboard</h1>

    <div class="grid grid-cols-3 gap-4 mb-8">
      <div class="bg-white p-4 rounded-lg shadow"><strong><%= stats.users %></strong> Total Users</div>
      <div class="bg-white p-4 rounded-lg shadow"><strong><%= stats.applicants %></strong> Applicants</div>
      <div class="bg-white p-4 rounded-lg shadow"><strong><%= stats.recruiters %></strong> Recruiters</div>
      <div class="bg-white p-4 rounded-lg shadow"><strong><%= stats.jobs %></strong> Jobs</div>
      <div class="bg-white p-4 rounded-lg shadow"><strong><%= stats.applications %></strong> Applications</div>
      <div class="bg-white p-4 rounded-lg shadow"><strong><%= stats.shortlisted %></strong> Shortlisted</div>
    </div>

    <h2 class="text-xl font-bold mb-4">Audit Log (Blockchain Ledger)</h2>
    <div class="bg-white p-6 rounded-xl shadow overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b-2 border-gray-200">
            <th class="pb-2 px-2">Job</th>
            <th class="pb-2 px-2">Candidate Code</th>
            <th class="pb-2 px-2">Score</th>
            <th class="pb-2 px-2">Criteria</th>
            <th class="pb-2 px-2">Verification Hash</th>
            <th class="pb-2 px-2">Timestamp</th>
          </tr>
        </thead>
        <tbody>
          <% auditLog.forEach(entry => { %>
          <tr class="border-b border-gray-100">
            <td class="py-2 px-2"><%= entry.title %></td>
            <td class="py-2 px-2 font-mono"><%= entry.applicant_code %></td>
            <td class="py-2 px-2"><%= Math.round(entry.score) %>%</td>
            <td class="py-2 px-2"><%= entry.criteria %></td>
            <td class="py-2 px-2 font-mono text-xs text-gray-400"><%= entry.verification_hash?.substring(0, 16) %>...</td>
            <td class="py-2 px-2"><%= new Date(entry.created_at).toLocaleString() %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
      <% if (auditLog.length === 0) { %><p class="text-gray-400 text-center py-4">No entries yet</p><% } %>
    </div>
  </div>
</body>
</html>
